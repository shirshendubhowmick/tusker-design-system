{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "tsconfig.json",
    "pnpm-workspace.yaml",
    "eslint.config.mjs",
    ".prettierrc.json"
  ],
  "tasks": {
    "tokens:generate": {
      "cache": false
    },
    "exports:generate": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^typecheck"]
    },
    "test:coverage": {
      "dependsOn": ["^typecheck"],
      "outputs": ["coverage/**"]
    },
    "build": {
      "dependsOn": ["^tokens:generate", "^exports:generate"],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        "storybook-static/**"
      ]
    },
    "dev": {
      "dependsOn": ["^tokens:generate", "^exports:generate"],
      "cache": false,
      "persistent": true
    }
  }
}
