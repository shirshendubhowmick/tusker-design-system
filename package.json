{
  "name": "design-system-monorepo",
  "private": true,
  "description": "Monorepo for the design system and related apps",
  "scripts": {
    "tokens:generate": "pnpm --filter @design-system/ui tokens:generate",
    "tokens:check": "pnpm --filter @design-system/ui tokens:check",
    "dev": "pnpm --filter @design-system/ui dev",
    "build": "pnpm -r --filter @design-system/ui build",
    "storybook": "pnpm --filter @design-system/ui storybook",
    "build-storybook": "pnpm --filter @design-system/ui build-storybook",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.7.0",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
