{
  "name": "design-system-monorepo",
  "private": true,
  "description": "Monorepo for the design system and related apps",
  "scripts": {
    "tokens:generate": "pnpm --filter @design-system/ui tokens:generate",
    "tokens:check": "pnpm --filter @design-system/ui tokens:check",
    "dev": "pnpm --filter @design-system/ui dev",
    "build": "pnpm -r --filter @design-system/ui build",
    "storybook": "pnpm --filter @design-system/ui storybook",
    "build-storybook": "pnpm --filter @design-system/ui build-storybook",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "coverage": "pnpm -r --if-present coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.7.0",
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.10.4",
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown",
    "*.{js,jsx,mjs,cjs,ts,tsx,mts,cts}": "eslint --max-warnings=0",
    "{packages/ui/src/tokens/**/*.{ts,tsx},packages/ui/scripts/generate-tokens.mts}": "bash -c 'pnpm tokens:generate && git add packages/ui/src/tokens'"
  }
}
