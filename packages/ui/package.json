{
  "name": "@design-system/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Design system for a Dev tool SaaS — React, Tailwind, Radix Colors",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./Badge": "./src/components/Badge/index.ts",
    "./Button": "./src/components/Button/index.ts",
    "./Field": "./src/components/Field/index.ts",
    "./FormField": "./src/components/FormField/index.ts",
    "./IconButton": "./src/components/IconButton/index.ts",
    "./Input": "./src/components/Input/index.ts",
    "./Label": "./src/components/Label/index.ts",
    "./Spinner": "./src/components/Spinner/index.ts",
    "./Text": "./src/components/Text/index.ts",
    "./tokens": "./src/tokens/index.ts",
    "./cn": "./src/utils/cn.ts",
    "./focus-ring": "./src/utils/focus-ring.ts",
    "./surface": "./src/utils/surface.ts",
    "./overlay": "./src/utils/overlay.ts",
    "./styles.css": "./src/styles/index.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "tokens:generate": "node --experimental-strip-types ./scripts/generate-tokens.mts",
    "tokens:check": "node --experimental-strip-types ./scripts/generate-tokens.mts --check",
    "exports:generate": "node --experimental-strip-types ./scripts/gen-exports.mts",
    "exports:check": "node --experimental-strip-types ./scripts/gen-exports.mts --check",
    "build-storybook": "pnpm tokens:generate && pnpm exports:generate && storybook build",
    "storybook": "pnpm tokens:generate && pnpm exports:generate && storybook dev -p 6006 --no-open",
    "test": "vitest run --project unit",
    "test:unit": "vitest run --project unit",
    "test:storybook": "vitest run --project storybook-light --project storybook-dark",
    "test:storybook:light": "vitest run --project storybook-light",
    "test:storybook:dark": "vitest run --project storybook-dark",
    "test:storybook:ui": "vitest --project storybook-light --project storybook-dark --ui --api.host 0.0.0.0",
    "test:watch": "vitest",
    "test:coverage": "vitest run --project unit --coverage",
    "coverage": "vitest run --project unit --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@radix-ui/react-icons": "^1.3.0",
    "class-variance-authority": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "dependencies": {
    "@radix-ui/colors": "^3.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-links": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "4.1.9",
    "axe-core": "^4.12.1",
    "class-variance-authority": "catalog:",
    "jsdom": "^29.1.1",
    "playwright": "1.61.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "storybook": "10.4.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.7.0",
  "peerDependenciesMeta": {
    "@radix-ui/react-icons": {
      "optional": true
    }
  }
}
