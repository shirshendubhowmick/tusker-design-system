{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.node.tsbuildinfo"
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "scripts/**/*.mts",
    "scripts/**/*.ts",
    ".storybook/**/*",
    "src/vite-env.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
