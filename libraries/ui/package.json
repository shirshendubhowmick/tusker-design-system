{
  "name": "@design-system/ui",
  "version": "0.1.0",
  "description": "Design system for a Dev tool SaaS — React, Tailwind, Radix Colors",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/design-system.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "./dist/design-system.css"
  ],
  "scripts": {
    "tokens:generate": "node --experimental-strip-types ./scripts/generate-tokens.mts",
    "tokens:check": "node --experimental-strip-types ./scripts/generate-tokens.mts --check",
    "dev": "pnpm tokens:generate && storybook dev -p 6006",
    "build": "pnpm tokens:generate && tsc --noEmit && vite build && vite build --mode styles",
    "build-storybook": "pnpm tokens:generate && storybook build",
    "storybook": "pnpm tokens:generate && storybook dev -p 6006",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "class-variance-authority": "^0.7.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@radix-ui/colors": "^3.0.0",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-links": "10.4.6",
    "@storybook/react": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "class-variance-authority": "^0.7.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "10.4.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "tailwind-merge": "^3.6.0"
  }
}
